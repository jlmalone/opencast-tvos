<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleIconName</key>
	<string>App Icon &amp; Top Shelf Image</string>
	<key>CFBundleName</key>
	<string>OvrCast</string>
	<key>CFBundleDisplayName</key>
	<string>OvrCast</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_fcast._tcp</string>
	</array>
	<key>NSLocalNetworkUsageDescription</key>
	<string>OvrCast uses the local network to receive video and audio streams from FCast-compatible sender devices.</string>
	<key>UIApplicationIdleTimerDisabled</key>
	<true/>
	<!-- Media receiver: senders provide arbitrary URLs including http:// streams,
	     local network servers, and non-HTTPS media. AVFoundation media loads require
	     the media exception. Local networking covers WHEP/WebRTC SDP on LAN. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsForMedia</key>
		<true/>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
